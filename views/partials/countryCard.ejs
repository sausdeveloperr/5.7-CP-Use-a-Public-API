<!-- filepath: c:\Users\HP-PC\Documents\Salami Olamilekan\MERN\JS\Backend\5.7 CP Use a Public API\views\partials\countryCard.ejs -->
<article class="bg-white dark:bg-gray-800 rounded-3xl shadow-lg dark:shadow-gray-950 border border-gray-200 dark:border-gray-700 overflow-hidden transition-all duration-300">
  <!-- Main card content -->
  <div class="p-6 md:p-8">
    <!-- Flag and header section -->
    <div class="flex gap-6 mb-8">
      <!-- Flag image -->
      <div class="flex-shrink-0">
        <figure class="w-32 h-24 rounded-2xl overflow-hidden border-2 border-gray-300 dark:border-gray-600 bg-gradient-to-br from-gray-300 to-gray-400 dark:from-gray-700 dark:to-gray-600">
          <img 
            src="<%= country.flags.png %>" 
            alt="<%= country.flags.alt %>"
            class="w-full h-full object-cover animate-pulse"
            loading="lazy"
            onload="this.classList.remove('animate-pulse')"
          />
        </figure>
      </div>

      <!-- Country info section -->
      <div class="flex-1">
        <!-- Name info -->
        <div class="mb-6">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
            <%= country.name.common %>
          </h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 font-medium">
            <%= country.name.official %>
          </p>
        </div>

        <!-- Capital and locations -->
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-gray-500 dark:text-gray-400 text-xs uppercase font-semibold mb-1 flex items-center gap-1">
              <span class="material-icons text-base">location_city</span> Capital
            </p>
            <p class="text-gray-900 dark:text-gray-100 font-semibold">
              <%= country.capital ? country.capital.join(', ') : 'N/A' %>
            </p>
          </div>
          <div>
            <p class="text-gray-500 dark:text-gray-400 text-xs uppercase font-semibold mb-1 flex items-center gap-1">
              <span class="material-icons text-base">public</span> Region
            </p>
            <p class="text-gray-900 dark:text-gray-100 font-semibold">
              <%= country.region %>
            </p>
          </div>
          <div>
            <p class="text-gray-500 dark:text-gray-400 text-xs uppercase font-semibold mb-1 flex items-center gap-1">
              <span class="material-icons text-base">map</span> Subregion
            </p>
            <p class="text-gray-900 dark:text-gray-100 font-semibold">
              <%= country.subregion %>
            </p>
          </div>
          <div>
            <p class="text-gray-500 dark:text-gray-400 text-xs uppercase font-semibold mb-1 flex items-center gap-1">
              <span class="material-icons text-base">people</span> Demonym
            </p>
            <p class="text-gray-900 dark:text-gray-100 font-semibold">
              <%= country.demonyms?.eng?.m || 'N/A' %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick stats -->
    <div class="grid grid-cols-2 gap-4 mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
      <div class="flex items-start gap-3">
        <span class="material-icons text-blue-500 dark:text-blue-400 flex-shrink-0 mt-1">people</span>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold">Population</p>
          <p class="text-lg font-bold text-gray-900 dark:text-white">
            <%= (country.population / 1000000).toFixed(1) %>M
          </p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="material-icons text-blue-500 dark:text-blue-400 flex-shrink-0 mt-1">phone</span>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold">Dial Code</p>
          <p class="text-lg font-bold text-gray-900 dark:text-white">
            +<%= country.idd.root %><%= country.idd.suffixes ? country.idd.suffixes[0] : '' %>
          </p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="material-icons text-blue-500 dark:text-blue-400 flex-shrink-0 mt-1">
          <%= country.landlocked ? 'terrain' : 'water' %>
        </span>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold">Landlocked</p>
          <p class="text-lg font-bold text-gray-900 dark:text-white">
            <%= country.landlocked ? 'Yes' : 'No' %>
          </p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="material-icons text-blue-500 dark:text-blue-400 flex-shrink-0 mt-1">directions_car</span>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold">Car Side</p>
          <p class="text-lg font-bold text-gray-900 dark:text-white">
            <%= country.car.side === 'right' ? 'Right' : 'Left' %>
          </p>
        </div>
      </div>
    </div>

    <!-- Auxiliary details toggle button -->
    <button 
      id="toggleAuxiliary" 
      type="button"
      aria-expanded="false"
      aria-controls="auxiliaryDetails"
      class="w-full py-3 px-4 flex items-center justify-between bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-2xl border border-gray-300 dark:border-gray-600 transition-all duration-200 group"
    >
      <span class="font-semibold text-gray-900 dark:text-white flex items-center gap-2">
        <span class="material-icons text-lg">info</span>
        Auxiliary Details
      </span>
      <span class="material-icons text-gray-600 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white transition-transform duration-300" id="toggleIcon">expand_more</span>
    </button>

    <!-- add an accented disabled button below this that says "What's happening in this country?" and leads to another page -->

    <button 
      type="button"
      aria-label="What's happening in this country"
      title="Feature coming soon!"
      class="w-full px-3 md:px-4 py-1 md:py-1.5 mt-6 bg-blue-500 hover:scale-105 active:bg-blue-700 active:scale-95 dark:bg-blue-600 dark:hover:bg-blue-500 dark:active:bg-blue-700 text-white font-semibold rounded-2xl flex items-center justify-center gap-2 transition-all duration-200 hover:shadow-lg active:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-400 dark:focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
      style="background-color: var(--color-accent);"
      disabled
    >
      <span class="material-icons text-lg md:text-xl">newspaper</span>
      <span>What's happening in this country?</span>
    </button>
  </div>

  <!-- Auxiliary details section (collapsed by default) -->
  <div 
    id="auxiliaryDetails"
    class="hidden max-h-0 overflow-hidden transition-all duration-300"
  >
    <div class="p-6 md:p-8 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
      <!-- Timezones -->
      <section class="mb-8">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="material-icons">schedule</span>
          Timezones
        </h3>
        <div class="flex flex-wrap gap-2">
          <% country.timezones.forEach(tz => { %>
            <span class="px-3 py-2 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-gray-100">
              <%= tz %>
            </span>
          <% }); %>
        </div>
      </section>

      <!-- Languages -->
      <section class="mb-8">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="material-icons">language</span>
          Languages
        </h3>
        <div class="flex flex-wrap gap-2">
          <% Object.values(country.languages).forEach(lang => { %>
            <span class="px-3 py-2 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 text-sm font-medium text-gray-900 dark:text-gray-100">
              <%= lang %>
            </span>
          <% }); %>
        </div>
      </section>

      <!-- Currencies -->
      <section class="mb-8">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="material-icons">attach_money</span>
          Currencies
        </h3>
        <div class="grid gap-3">
          <% Object.entries(country.currencies).forEach(([code, curr]) => { %>
            <div class="flex items-center justify-between p-3 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
              <div>
                <p class="font-semibold text-gray-900 dark:text-white"><%= code %></p>
                <p class="text-sm text-gray-600 dark:text-gray-400"><%= curr.name %></p>
              </div>
              <span class="text-lg font-bold text-blue-500 dark:text-blue-400"><%= curr.symbol %></span>
            </div>
          <% }); %>
        </div>
      </section>

      <!-- Additional info -->
      <section>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <span class="material-icons">more_horiz</span>
          Additional Info
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-3 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold mb-1">Week Start</p>
            <p class="font-semibold text-gray-900 dark:text-white capitalize">
              <%= country.startOfWeek || 'N/A' %>
            </p>
          </div>
          <div class="p-3 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            <p class="text-xs text-gray-500 dark:text-gray-400 uppercase font-semibold mb-1">UN Member</p>
            <p class="font-semibold text-gray-900 dark:text-white">
              <%= country.unmember ? 'Yes' : 'No' %>
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>
</article>